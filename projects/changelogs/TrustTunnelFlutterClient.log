diff --git a/lib/data/model/certificate.dart b/lib/data/model/certificate.dart
new file mode 100644
index 0000000..a4f52ab
--- /dev/null
+++ b/lib/data/model/certificate.dart
@@ -0,0 +1,28 @@
+import 'package:meta/meta.dart';
+
+@immutable
+class Certificate {
+  final String name;
+  final String data;
+
+  const Certificate({
+    required this.name,
+    required this.data,
+  });
+
+  @override
+  int get hashCode => Object.hashAll([
+    name.hashCode,
+    data.hashCode,
+  ]);
+
+  @override
+  String toString() => 'Certificate(name: $name, data: $data)';
+
+  @override
+  bool operator ==(covariant Certificate other) {
+    if (identical(this, other)) return true;
+
+    return other.name == name && other.data == data;
+  }
+}
