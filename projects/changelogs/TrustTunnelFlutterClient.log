diff --git a/lib/common/models/value_data.dart b/lib/common/models/value_data.dart
new file mode 100644
index 0000000..474fe4d
--- /dev/null
+++ b/lib/common/models/value_data.dart
@@ -0,0 +1,23 @@
+import 'package:meta/meta.dart';
+
+@immutable
+class ValueData<T> {
+  final T? value;
+
+  const ValueData(
+    this.value,
+  );
+
+  @override
+  int get hashCode => value.hashCode;
+
+  @override
+  String toString() => value.toString();
+
+  @override
+  bool operator ==(covariant ValueData<T> other) {
+    if (identical(this, other)) return true;
+
+    return other.value == value;
+  }
+}
