 }
 
-#[macro_export] macro_rules! debug { ($($arg:tt)*) => { log_println!(LogLevel::Debug, $($arg)*) } }
-#[macro_export] macro_rules! info { ($($arg:tt)*) => { log_println!(LogLevel::Info,  $($arg)*) } }
-#[macro_export] macro_rules! warn { ($($arg:tt)*) => { log_println!(LogLevel::Warning,$($arg)*) } }
-#[macro_export] macro_rules! error { ($($arg:tt)*) => { log_println!(LogLevel::Error,  $($arg)*) } }
+#[macro_export]
+macro_rules! debug {
+    ($($arg:tt)*) => {
+        crate::log_println!(crate::log::LogLevel::Debug, $($arg)*)
+    }
+}
+
+#[macro_export]
+macro_rules! info {
+    ($($arg:tt)*) => {
+        crate::log_println!(crate::log::LogLevel::Info, $($arg)*)
+    }
+}
+
+#[macro_export]
+macro_rules! warn {
+    ($($arg:tt)*) => {
+        crate::log_println!(crate::log::LogLevel::Warning, $($arg)*)
+    }
+}
+
+#[macro_export]
+macro_rules! error {
+    ($($arg:tt)*) => {
+        crate::log_println!(crate::log::LogLevel::Error, $($arg)*)
+    }
+}
 
