+++ b/dpibreak.1.in
@@ -1,4 +1,4 @@
-.TH DPIBREAK 1 "March 2026" "DPIBreak {{VERSION}}" "User Commands"
+.TH DPIBREAK 1 "April 2026" "DPIBreak {{VERSION}}" "User Commands"
