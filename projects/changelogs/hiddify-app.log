commit 53e3b85fbbf9d81f3f80d58e7d20b01f26fe2672
Author: Hiddify <114227601+hiddify-com@users.noreply.github.com>
Date:   2025-03-11 20:46:24 +0100

    Create super_fragment.json
---
 test.configs/super_fragment.json | 142 +++++++++++++++++++++++++++++++++++++++
 1 file changed, 142 insertions(+)

diff --git a/test.configs/super_fragment.json b/test.configs/super_fragment.json
new file mode 100644
index 00000000..c6458346
--- /dev/null
+++ b/test.configs/super_fragment.json
@@ -0,0 +1,142 @@
+{
+  "outbounds": [
+    {
+      "type": "xray",
+      "tag": "XFragment",
+      "udp_over_tcp": true,
+      "xconfig": {
+        "dns": {
+          "disableFallback": true,
+          "hosts": {
+            "dns.cloudflare.com": "cloudflare.com"
+          },
+          "servers": [
+            "https://dns.cloudflare.com/dns-query",
+            {
+              "address": "localhost",
+              "domains": [
+                "full:cloudflare.com"
+              ]
+            }
+          ],
+          "tag": "dns-query"
+        },
+        "log": {
+          "access": "none",
+          "dnsLog": false,
+          "loglevel": "warning"
+        },
+        "outbounds": [
+          {
+            "domainStrategy": "AsIs",
+            "protocol": "freedom",
+            "streamSettings": {
+              "sockopt": {
+                "tcpKeepAliveIdle": 100,
+                "tcpNoDelay": true
+              }
+            },
+            "tag": "XFragment1"
+          },
+          {
+            "protocol": "blackhole",
+            "tag": "block"
+          },
+          {
+            "protocol": "freedom",
+            "settings": {
+              "domainStrategy": "ForceIP"
+            },
+            "tag": "direct"
+          },
+          {
+            "protocol": "dns",
+            "settings": {
+              "address": "1.1.1.1",
+              "network": "tcp",
+              "nonIPQuery": "skip",
+              "port": 53
+            },
+            "streamSettings": {
+              "sockopt": {
+                "dialerProxy": "chain1-fragment"
+              }
+            },
+            "tag": "dns-out"
+          },
+          {
+            "protocol": "freedom",
+            "settings": {
+              "fragment": {
+                "interval": "0",
+                "length": "6",
+                "packets": "tlshello"
+              }
+            },
+            "streamSettings": {
+              "sockopt": {
+                "dialerProxy": "chain1-fragment"
+              }
+            },
+            "tag": "super-fragment"
+          },
+          {
+            "protocol": "freedom",
+            "settings": {
+              "fragment": {
+                "interval": "1",
+                "length": "517",
+                "packets": "1-3"
+              }
+            },
+            "streamSettings": {
+              "sockopt": {
+                "dialerProxy": "chain2-fragment"
+              }
+            },
+            "tag": "chain1-fragment"
+          },
+          {
+            "protocol": "freedom",
+            "settings": {
+              "domainStrategy": "ForceIP",
+              "fragment": {
+                "interval": "2",
+                "length": "1",
+                "packets": "1-1"
+              }
+            },
+            "streamSettings": {
+              "sockopt": {
+                "tcpNoDelay": true
+              }
+            },
+            "tag": "chain2-fragment"
+          }
+        ],
+        "routing": {
+          "domainStrategy": "IPOnDemand",
+          "rules": [
+            {
+              "inboundTag": [
+                "dns-query"
+              ],
+              "network": "tcp",
+              "outboundTag": "chain1-fragment"
+            },
+            {
+              "ip": [
+                "10.10.34.0/24",
+                "2001:4188:2:600:10:10:34:36",
+                "2001:4188:2:600:10:10:34:35",
+                "2001:4188:2:600:10:10:34:34"
+              ],
+              "outboundTag": "block"
+            }
+          ]
+        }
+      },
+      "xdebug": false
+    }
+  ]
+}

