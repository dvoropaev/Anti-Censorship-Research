Author: Hiddify <114227601+hiddify-com@users.noreply.github.com>
Date:   2026-02-14 00:13:00 +0100

    Modify stale.yml for cron schedule and messages
    
    Updated the stale issue workflow to change the cron schedule and modify the stale issue message and timing.
---
 .github/workflows/stale.yml | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/.github/workflows/stale.yml b/.github/workflows/stale.yml
new file mode 100644
index 00000000..d51f584d
--- /dev/null
+++ b/.github/workflows/stale.yml
@@ -0,0 +1,16 @@
+name: Mark stale issues and pull requests
+
+on:
+  schedule:
+    - cron: "30 7 * * *"
+
+jobs:
+  stale:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/stale@v9
+        with:
+          stale-issue-message: 'With the release of v4.0.0 (pre-release), most reported issues have been fixed. We’re closing all current issues to start fresh.If you’re still experiencing the problem, please open a new issue and let us know.'
+          days-before-stale: 2
+          days-before-close: 1
+          

