Author: Yuriy Selivanov <y.selivanov@adguard.com>
Date:   2026-04-15 18:27:06 +0000

    Pull request 669: Fix use-after-free in start_location_ping
    
    Squashed commit of the following:
    
    commit 38ceff04e656c6db7a0a11a7edf4d37558c9b6b3
    Author: Yuriy Selivanov <y.selivanov@adguard.com>
    Date:   Tue Apr 7 23:14:31 2026 +0300
    
        fix crash
    
    commit 50c4cd533f65314040b67b965533692c94466edd
    Author: Yuriy Selivanov <y.selivanov@adguard.com>
    Date:   Tue Apr 7 21:05:22 2026 +0300
    
        add test for this crash
---
 net/src/locations_pinger.cpp               | 18 +++++++++++-------
 net/test/test_locations_pinger_offline.cpp | 26 ++++++++++++++++++++++++++
 2 files changed, 37 insertions(+), 7 deletions(-)

diff --git a/net/src/locations_pinger.cpp b/net/src/locations_pinger.cpp
index 2bd5b13..70b1b08 100644
--- a/net/src/locations_pinger.cpp
+++ b/net/src/locations_pinger.cpp
@@ -265,14 +265,12 @@ static void start_location_ping(LocationsPinger *pinger) {
             pinger->anti_dpi, pinger->handoff, {i->info->relays.data, i->info->relays.size}, *pinger->relay_parallel,
             pinger->quic_max_idle_timeout_ms, pinger->quic_version};
     Ping *ping = ping_start(&ping_info, {ping_handler, pinger});
-    if (!ping) {
-        FinalizeLocationInfo info{std::move(*i), pinger->pending_locations.size() == 1 && pinger->locations.empty()};
-        finalize_location(pinger, std::move(info));
-    } else {
-        pinger->locations.emplace(ping, std::move(*i));
-    }
-    pinger->pending_locations.pop_front();
 
+    // Must be extracted before pop_front() invalidates the iterator, and before finalize_location()
+    // is called, since the callback inside it may destroy the pinger.
+    FinalizeLocationInfo info{std::move(*i), pinger->pending_locations.size() == 1 && pinger->locations.empty()};
+
+    pinger->pending_locations.pop_front();
     if (!pinger->pending_locations.empty()) {
         pinger->task_id = event_loop::schedule(pinger->loop,
                 {
@@ -284,6 +282,12 @@ static void start_location_ping(LocationsPinger *pinger) {
                 },
                 Millis{1} /*ms (force libevent to poll/select*/);
     }
+
+    if (!ping) {
+        finalize_location(pinger, std::move(info));
+    } else {
+        pinger->locations.emplace(ping, std::move(info.location_ctx));
+    }
 }
 
 LocationsPinger *locations_pinger_start(const LocationsPingerInfo *info, LocationsPingerHandler handler,
diff --git a/net/test/test_locations_pinger_offline.cpp b/net/test/test_locations_pinger_offline.cpp
index 5f3695e..d97e858 100644
--- a/net/test/test_locations_pinger_offline.cpp
+++ b/net/test/test_locations_pinger_offline.cpp
@@ -367,3 +367,29 @@ TEST_F(LocationsPingerOfflineTest, EmptyLocationsFinishesImmediately) {
     ASSERT_TRUE(test_ctx.finished);
     ASSERT_TRUE(test_ctx.results.empty());
 }
+
+TEST_F(LocationsPingerOfflineTest, DestroyFromCallbackWhenPingStartFails) {
+    // name == nullptr causes ping_start to return nullptr (empty name check)
+    VpnEndpoint endpoint = {sockaddr_from_str("1.1.1.1:443"), nullptr};
+    VpnLocation location = {"1", {&endpoint, 1}};
+
+    TestCtx test_ctx = generate_test_ctx();
+    test_ctx.info.locations = {&location, 1};
+
+    test_ctx.pinger.reset(locations_pinger_start(&test_ctx.info,
+            {
+                    [](void *arg, const LocationsPingerResult *result) {
+                        auto *ctx = (TestCtx *) arg;
+                        if (result == nullptr) {
+                            // "Done" signal: destroy pinger while still on the call stack of
+                            // start_location_ping. Without a fix this causes use-after-free.
+                            ctx->pinger.reset();
+                            vpn_event_loop_exit(ctx->loop, Millis{0});
+                        }
+                    },
+                    &test_ctx,
+            },
+            loop.get(), network_manager.get()));
+
+    run_event_loop();
+}
\ No newline at end of file

