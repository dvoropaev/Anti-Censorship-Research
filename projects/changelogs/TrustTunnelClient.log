    Pull request 671: fix vpn-libs: SocksListener::send returns 0 instead of length for TCP
    
    Squashed commit of the following:
    
    commit 9a30af5c674463901e0b681d7c10b540f85c224a
    Author: Radmir Sadikov <r.sadikov@adguard.com>
    Date:   Mon Apr 13 12:42:43 2026 +0400
    
        use kh_value to get protocol type instead of mapping
    
    commit e1c2ad653700a9824e8d5d21f4dc751f94e797e9
    Author: Radmir Sadikov <r.sadikov@adguard.com>
    Date:   Fri Apr 10 14:06:53 2026 +0400
    
        fix vpn-libs: SocksListener::send returns 0 instead of length for TCP
---
 core/src/socks_listener.cpp       |  5 ++++-
 net/include/net/socks5_listener.h |  9 +++++++++
 net/src/socks5_listener.cpp       | 11 +++++++++++
 3 files changed, 24 insertions(+), 1 deletion(-)

diff --git a/core/src/socks_listener.cpp b/core/src/socks_listener.cpp
index ec962fa..3432729 100644
--- a/core/src/socks_listener.cpp
+++ b/core/src/socks_listener.cpp
@@ -198,7 +198,10 @@ void SocksListener::close_connection(uint64_t id, bool graceful, bool async) {
 ssize_t SocksListener::send(uint64_t id, const uint8_t *data, size_t length) {
     int r = socks5_listener_send_data(m_socks5_listener, id, data, length);
     if (r == 0) {
-        r = (int) length;
+        int proto = 0;
+        if (socks5_listener_get_connection_proto(m_socks5_listener, id, proto) && proto != IPPROTO_TCP) {
+            r = (int) length;
+        }
     }
     return r;
 }
