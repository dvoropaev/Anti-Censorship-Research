commit e9ffba86a3f818c21e898ca453047555a89ef50f
Author: Sergey Fionov <sfionov@adguard.com>
Date:   2026-03-27 15:46:15 +0000

    Pull request 661: Use static deeplink_ffi library for Apple
    
    Squashed commit of the following:
    
    commit 9bad1c1bbf7bca3b843a1439081cb0f87b7f44d7
    Author: Sergey Fionov <sfionov@adguard.com>
    Date:   Fri Mar 27 17:19:23 2026 +0200
    
        Use static deeplink_ffi library for Apple
---
 platform/apple/VpnClient/CMakeLists.txt  | 12 ------------
 platform/apple/VpnClient/build_client.sh |  5 -----
 trusttunnel/CMakeLists.txt               | 24 ++----------------------
 3 files changed, 2 insertions(+), 39 deletions(-)

diff --git a/platform/apple/VpnClient/CMakeLists.txt b/platform/apple/VpnClient/CMakeLists.txt
index 679617a..02d67de 100644
--- a/platform/apple/VpnClient/CMakeLists.txt
+++ b/platform/apple/VpnClient/CMakeLists.txt
@@ -61,18 +61,6 @@ set_target_properties(${PROJECT_NAME} PROPERTIES
 target_link_options(${PROJECT_NAME} PRIVATE "-ObjC")
 
 target_link_libraries(${PROJECT_NAME} vpnlibs_trusttunnel trusttunnel_deeplink_ffi)
-
-# Embed the deeplink FFI dylib in the framework bundle so it's found at runtime.
-# The dylib is built as cdylib to avoid duplicate Rust std symbols with libquiche.a.
-# Its install name is already set to @rpath/... by the ExternalProject step.
-get_target_property(DEEPLINK_FFI_DYLIB trusttunnel_deeplink_ffi IMPORTED_LOCATION)
-add_custom_command(TARGET ${PROJECT_NAME} POST_BUILD
-        COMMAND ${CMAKE_COMMAND} -E make_directory "$<TARGET_BUNDLE_DIR:${PROJECT_NAME}>/Frameworks"
-        COMMAND ${CMAKE_COMMAND} -E copy "${DEEPLINK_FFI_DYLIB}" "$<TARGET_BUNDLE_DIR:${PROJECT_NAME}>/Frameworks/libtrusttunnel_deeplink_ffi.dylib"
-        COMMENT "Embedding libtrusttunnel_deeplink_ffi.dylib in framework"
-)
-target_link_options(${PROJECT_NAME} PRIVATE "-Wl,-rpath,@loader_path/Frameworks")
-
 target_link_libraries(${PROJECT_NAME} "-framework Foundation" "-framework NetworkExtension")
 
 set_property(SOURCE module.modulemap PROPERTY MACOSX_PACKAGE_LOCATION "Modules")
diff --git a/platform/apple/VpnClient/build_client.sh b/platform/apple/VpnClient/build_client.sh
index 295395a..70842b8 100755
--- a/platform/apple/VpnClient/build_client.sh
+++ b/platform/apple/VpnClient/build_client.sh
@@ -146,9 +146,6 @@ function build_target() {
         exit 1
     fi
 
-    install_name_tool -change @rpath/libtrusttunnel_deeplink_ffi.dylib @rpath/${target_name}.framework/Frameworks/libtrusttunnel_deeplink_ffi.dylib \
-        ${target_name}.framework/${target_name}
-
     if [ -n "${CODESIGN_IDENTITY}" ]; then
         codesign --force --sign "${CODESIGN_IDENTITY}" --options runtime --timestamp "${target_name}.framework"
     fi
@@ -178,12 +175,10 @@ mkdir -p "${BUILD_DIR}/framework-macos"
 cp -Rf "${BUILD_DIR}/framework-macos-x86_64/${TARGET_NAME}.framework" "${BUILD_DIR}/framework-macos/"
 rm "${BUILD_DIR}/framework-macos/${TARGET_NAME}.framework/Versions/A/${TARGET_NAME}"
 lipo -create -output "${BUILD_DIR}"/framework-macos{,-x86_64,-arm64}/"${TARGET_NAME}.framework/Versions/A/${TARGET_NAME}"
-lipo -create -output "${BUILD_DIR}"/framework-macos{,-x86_64,-arm64}/"${TARGET_NAME}.framework/Frameworks/libtrusttunnel_deeplink_ffi.dylib"
 mkdir -p "${BUILD_DIR}/framework-iphonesimulator"
 cp -Rf "${BUILD_DIR}/framework-iphonesimulator-x86_64/${TARGET_NAME}.framework" "${BUILD_DIR}/framework-iphonesimulator/"
 rm "${BUILD_DIR}/framework-iphonesimulator/${TARGET_NAME}.framework/${TARGET_NAME}"
 lipo -create -output "${BUILD_DIR}"/framework-iphonesimulator{,-x86_64,-arm64}/"${TARGET_NAME}.framework/${TARGET_NAME}"
-lipo -create -output "${BUILD_DIR}"/framework-iphonesimulator{,-x86_64,-arm64}/"${TARGET_NAME}.framework/Frameworks/libtrusttunnel_deeplink_ffi.dylib"
 
 dsymutil -o "${BUILD_DIR}/framework-ios/${TARGET_NAME}.framework.dSYM" "${BUILD_DIR}/framework-ios/${TARGET_NAME}.framework/${TARGET_NAME}"
 dsymutil -o "${BUILD_DIR}/framework-iphonesimulator/${TARGET_NAME}.framework.dSYM" "${BUILD_DIR}/framework-iphonesimulator/${TARGET_NAME}.framework/${TARGET_NAME}"
diff --git a/trusttunnel/CMakeLists.txt b/trusttunnel/CMakeLists.txt
index 3d08ea2..bbb8471 100644
--- a/trusttunnel/CMakeLists.txt
+++ b/trusttunnel/CMakeLists.txt
@@ -92,14 +92,7 @@ endif ()
 
 set(RUST_WORKSPACE_TARGET_DIR ${CMAKE_CURRENT_BINARY_DIR}/rust_workspace)
 set(DEEPLINK_FFI_STATICLIB_NAME ${CMAKE_STATIC_LIBRARY_PREFIX}trusttunnel_deeplink_ffi${CMAKE_STATIC_LIBRARY_SUFFIX})
-if (APPLE)
-    # On Apple, use cdylib (.dylib) to avoid duplicate Rust std symbols with libquiche.a.
-    # A cdylib encapsulates Rust std inside the dynamic library, so symbols don't leak
-    # into the global namespace and can't conflict with libquiche.a's bundled copy.
-    set(DEEPLINK_FFI_LIBNAME libtrusttunnel_deeplink_ffi.dylib)
-else ()
-    set(DEEPLINK_FFI_LIBNAME ${DEEPLINK_FFI_STATICLIB_NAME})
-endif ()
+set(DEEPLINK_FFI_LIBNAME ${DEEPLINK_FFI_STATICLIB_NAME})
 
 set(CARGO_ENV_RUSTFLAGS "RUSTFLAGS=")
 if (ANDROID)
@@ -249,20 +242,7 @@ else ()
     add_dependencies(run_setup_wizard setup_wizard)
 endif ()
 
-if (APPLE)
-    # Fix the dylib install name before anything links against it, so the consuming
-    # framework records @rpath/... instead of the absolute build path.
-    ExternalProject_Add_Step(${DEEPLINK_FFI_BUILD_TARGET} fix_dylib_install_name
-            DEPENDEES build
-            DEPENDERS install
-            ALWAYS TRUE
-            COMMAND install_name_tool -id @rpath/libtrusttunnel_deeplink_ffi.dylib ${DEEPLINK_FFI_LIBFILE}
-            COMMENT "Setting install name for libtrusttunnel_deeplink_ffi.dylib"
-    )
-    add_library(trusttunnel_deeplink_ffi SHARED IMPORTED GLOBAL)
-else ()
-    add_library(trusttunnel_deeplink_ffi STATIC IMPORTED GLOBAL)
-endif ()
+add_library(trusttunnel_deeplink_ffi STATIC IMPORTED GLOBAL)
 set_target_properties(trusttunnel_deeplink_ffi PROPERTIES
     IMPORTED_LOCATION "${DEEPLINK_FFI_LIBFILE}"
     INTERFACE_INCLUDE_DIRECTORIES "${CMAKE_CURRENT_SOURCE_DIR}/deeplink-ffi/include"

