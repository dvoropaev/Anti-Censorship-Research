commit fcdb9e0ac36e46afcdeec290e99d2f7be0815622
Author: Aleksei Zhavoronkov <a.zhavoronkov@adguard.com>
Date:   2026-02-25 16:28:21 +0000

    Pull request 633: Fix missing arch
    
    Squashed commit of the following:
    
    commit e9eb2bdc57fda8c1867030a7caccead6183d7ae8
    Author: Zhavoronkov Aleksei <a.zhavoronkov@adguard.com>
    Date:   Wed Feb 25 19:08:09 2026 +0300
    
        Fix missing arch
---
 trusttunnel/CMakeLists.txt | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/trusttunnel/CMakeLists.txt b/trusttunnel/CMakeLists.txt
index 4a504c1..45e0add 100644
--- a/trusttunnel/CMakeLists.txt
+++ b/trusttunnel/CMakeLists.txt
@@ -112,6 +112,9 @@ if (ANDROID)
     elseif (ANDROID_ABI STREQUAL "x86_64")
         set(CARGO_TARGET ndk --target=x86_64-linux-android --platform=21 build)
         set(TARGET_SUBDIR "x86_64-linux-android/${TARGET_SUBDIR}")
+    elseif (ANDROID_ABI STREQUAL "x86")
+        set(CARGO_TARGET ndk --target=i686-linux-android --platform=21 build)
+        set(TARGET_SUBDIR "i686-linux-android/${TARGET_SUBDIR}")
     else ()
         message(FATAL_ERROR "Unsupported Android ABI: ${ANDROID_ABI}")
     endif ()

