Date:   2026-04-07 12:50:26 +0000

    Pull request 665: Fix crash in ConnectionInfo::to_json
    
    Squashed commit of the following:
    
    commit 36aa59e54b9f8d056ee4c9dc1b4b8598ea98ea1e
    Author: Andrey Yakushin <a.yakushin@adguard.com>
    Date:   Mon Apr 6 18:22:04 2026 +0400
    
        Extend tests for domain extractor
    
    commit 850ab8389d551806c4455e7c41796b2dacf5ce9b
    Author: Andrey Yakushin <a.yakushin@adguard.com>
    Date:   Mon Apr 6 18:21:53 2026 +0400
    
        Ignore domains that contains non-ascii or control characters ascii symbols in domain extractor
    
    commit 38ce71c23f0947446d8eb2b00a77a0ef88ccc26d
    Author: Andrey Yakushin <a.yakushin@adguard.com>
    Date:   Thu Apr 2 17:18:24 2026 +0400
    
        Use replace error handler for connection info json
---
 core/src/domain_extractor.cpp       | 16 ++++++++++++++++
 core/test/test_domain_extractor.cpp |  2 ++
 trusttunnel/src/connection_info.cpp |  2 +-
 3 files changed, 19 insertions(+), 1 deletion(-)

diff --git a/core/src/domain_extractor.cpp b/core/src/domain_extractor.cpp
index e038384..c56cdb8 100644
--- a/core/src/domain_extractor.cpp
+++ b/core/src/domain_extractor.cpp
@@ -1,5 +1,6 @@
 #include "vpn/internal/domain_extractor.h"
 
+#include <algorithm>
 #include <cassert>
 #include <memory>
 #include <string_view>
@@ -11,6 +12,8 @@
 
 namespace ag {
 
+static Logger g_logger("DOMAIN_EXTRACTOR");
+
 struct Parser { // NOLINT(cppcoreguidelines-special-member-functions,hicpp-special-member-functions)
     virtual ~Parser() = default;
     virtual DomainExtractorResult parse(DomainExtractorPacketDirection dir, std::vector<uint8_t> *buffer) = 0;
@@ -269,6 +272,19 @@ DomainExtractorResult DomainExtractor::proceed(
     }
 
     DomainExtractorResult r = m_context->parse(dir, data, length);
+
+    // Domain names must be ASCII per RFC 6066 (SNI) and RFC 7230 (HTTP Host).
+    // Non-ASCII bytes indicate malformed protocol data, not a valid domain.
+    // Lower bound constraint excludes (0x1F) control characters,
+    // upper bound constraint (0x7F) excludes non-ASCII bytes.
+    if (r.status == DES_FOUND && !std::all_of(r.domain.begin(), r.domain.end(), [](unsigned char c) {
+            return c > 0x1F && c < 0x7F;
+        })) {
+        warnlog(g_logger, "Domain name has been found, but contains non-ascii characters: {}",
+                utils::encode_to_hex({(uint8_t *) r.domain.data(), r.domain.size()}));
+        return {DES_NOTFOUND};
+    }
+
     return r;
 }
 
diff --git a/core/test/test_domain_extractor.cpp b/core/test/test_domain_extractor.cpp
index 514ee6d..6a57bbc 100644
--- a/core/test/test_domain_extractor.cpp
+++ b/core/test/test_domain_extractor.cpp
@@ -214,6 +214,8 @@ static const TestParam HTTP_TEST_SAMPLES[] = {
         {string_view_to_vector("CONNECT /example HTTP/1.1\r\nAccept: text/html\r\n\r\n"), DEPD_OUTGOING, DES_NOTFOUND,
                 ""},
         {string_view_to_vector("CONNECT example.com"), DEPD_OUTGOING, DES_NOTFOUND, ""},
+        // Control characters in Host header must be rejected as DES_NOTFOUND
+        {string_view_to_vector("GET / HTTP/1.1\r\nHost: exam\x01ple.com\r\n\r\n"), DEPD_OUTGOING, DES_NOTFOUND, ""},
 };
 INSTANTIATE_TEST_SUITE_P(DomainExtractorHTTP, OutgoingDataTcp, testing::ValuesIn(HTTP_TEST_SAMPLES));
 
diff --git a/trusttunnel/src/connection_info.cpp b/trusttunnel/src/connection_info.cpp
index cc53a99..4426456 100644
--- a/trusttunnel/src/connection_info.cpp
+++ b/trusttunnel/src/connection_info.cpp
@@ -35,7 +35,7 @@ std::string ConnectionInfo::to_json(VpnConnectionInfoEvent *info, bool include_c
         json["date"] = format_gmtime(ag::SystemClock::now(), "%Y-%m-%dT%H:%M:%S.%fZ");
     }
 
-    return json.dump();
+    return json.dump(-1, ' ', false, nlohmann::detail::error_handler_t::replace);
 }
 
 } // namespace ag

