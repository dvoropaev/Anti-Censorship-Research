commit 024872e42f77ec605ccd1eccdd73597239aa797d
Author: Aleksei Zhavoronkov <a.zhavoronkov@adguard.com>
Date:   2026-02-26 07:51:47 +0000

    Pull request 635: Fix ios-sim matching in CMake
    
    Squashed commit of the following:
    
    commit 14e659700fe162bb6a17008e72acdfd5c3a94e6a
    Merge: ace389fe 30bbabd4
    Author: Zhavoronkov Aleksei <a.zhavoronkov@adguard.com>
    Date:   Thu Feb 26 10:31:24 2026 +0300
    
        Merge remote-tracking branch 'origin/master' into fix/TRUST-388
    
    commit ace389fe6be3321f08a85b8540514738b39e0840
    Author: Zhavoronkov Aleksei <a.zhavoronkov@adguard.com>
    Date:   Thu Feb 26 10:30:30 2026 +0300
    
        Fix ios-sim matching in CMake
    
    commit e9eb2bdc57fda8c1867030a7caccead6183d7ae8
    Author: Zhavoronkov Aleksei <a.zhavoronkov@adguard.com>
    Date:   Wed Feb 25 19:08:09 2026 +0300
    
        Fix missing arch
---
 trusttunnel/CMakeLists.txt | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/trusttunnel/CMakeLists.txt b/trusttunnel/CMakeLists.txt
index 45e0add..3d08ea2 100644
--- a/trusttunnel/CMakeLists.txt
+++ b/trusttunnel/CMakeLists.txt
@@ -123,7 +123,8 @@ if (ANDROID)
     endif ()
 elseif (APPLE)
     if (CMAKE_SYSTEM_NAME STREQUAL "iOS")
-        if (CMAKE_OSX_SYSROOT STREQUAL "iphonesimulator")
+        string(TOLOWER "${CMAKE_OSX_SYSROOT}" CMAKE_OSX_SYSROOT_LOWER)
+        if (CMAKE_OSX_SYSROOT_LOWER MATCHES "simulator")
             if (CMAKE_OSX_ARCHITECTURES STREQUAL "arm64")
                 set(CARGO_TARGET --target aarch64-apple-ios-sim)
                 set(TARGET_SUBDIR "aarch64-apple-ios-sim/${TARGET_SUBDIR}")

