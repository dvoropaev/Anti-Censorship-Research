Author: 风扇滑翔翼 <Fangliding.fshxy@outlook.com>
Date:   2026-02-12 22:00:15 +0800

    core/core.go: Replace "Custom" with vcs info if available (#5665)
    
    https://github.com/XTLS/Xray-core/pull/5665#issuecomment-3890500863
---
 core/core.go | 29 +++++++++++++++++++++++++++++
 1 file changed, 29 insertions(+)

diff --git a/core/core.go b/core/core.go
index b35bef59..e5dbf7d7 100644
--- a/core/core.go
+++ b/core/core.go
@@ -12,6 +12,7 @@ package core
 import (
 	"fmt"
 	"runtime"
+	"runtime/debug"
 
 	"github.com/xtls/xray-core/common/serial"
 )
@@ -28,6 +29,34 @@ var (
 	intro    = "A unified platform for anti-censorship."
 )
 
+func init() {
+	// Manually injected
+	if build != "Custom" {
+		return
+	}
+	info, ok := debug.ReadBuildInfo()
+	if !ok {
+		return
+	}
+	var isDirty bool
+	var foundBuild bool
+	for _, setting := range info.Settings {
+		switch setting.Key {
+		case "vcs.revision":
+			if len(setting.Value) < 7 {
+				return
+			}
+			build = setting.Value[:7]
+			foundBuild = true
+		case "vcs.modified":
+			isDirty = setting.Value == "true"
+		}
+	}
+	if isDirty && foundBuild {
+		build += "-dirty"
+	}
+}
+
