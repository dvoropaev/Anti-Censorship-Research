+			return windows.SetsockoptInt(windows.Handle(fd), windows.IPPROTO_IPV6, windows.IPV6_MULTICAST_IF, iface.Index)
+		}
+	default:
+		return errors.New("unknown network ", network)
+	}
+
+	return nil
 }
