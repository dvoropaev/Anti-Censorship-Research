 transport/internet/finalmask/xdns/client.go    | 248 ++++++++++++++++++-------
 transport/internet/finalmask/xdns/config.go    |  12 ++
 transport/internet/finalmask/xdns/config.pb.go |  23 ++-
 transport/internet/finalmask/xdns/config.proto |   6 +-
 transport/internet/finalmask/xdns/dns_test.go  |   1 +
 transport/internet/finalmask/xdns/server.go    |  38 ++--
 transport/internet/finalmask/xicmp/client.go   |  10 +-
 transport/internet/finalmask/xicmp/config.go   |  16 +-
 transport/internet/finalmask/xicmp/server.go   |   6 +-
