-        IpAddr::V6(v6) => v6.to_ipv4_mapped().map(IpAddr::V4).unwrap_or(ip),
+        IpAddr::V6(v6) => extract_ipv4_from_ipv6(&v6).map(IpAddr::V4).unwrap_or(ip),
