diff --git a/lib/src/net_utils.rs b/lib/src/net_utils.rs
index 80dc271..8927c0b 100644
--- a/lib/src/net_utils.rs
+++ b/lib/src/net_utils.rs
@@ -166,6 +166,101 @@ pub(crate) fn bind_to_interface(
