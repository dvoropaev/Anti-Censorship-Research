Author: Toby <tobyxdd@gmail.com>
Date:   2026-04-25 17:31:19 -0700

    ci: update actions version & bump go to 1.26
---
 .github/workflows/build-common.yml | 8 ++++----
 .github/workflows/docker.yml       | 2 +-
 .github/workflows/release.yml      | 4 ++--
 .github/workflows/scripts.yml      | 2 +-
 .github/workflows/test.yml         | 2 +-
 5 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/.github/workflows/build-common.yml b/.github/workflows/build-common.yml
index a2a3d82..6347174 100644
--- a/.github/workflows/build-common.yml
+++ b/.github/workflows/build-common.yml
@@ -14,15 +14,15 @@ jobs:
 
     steps:
       - name: Check out
-        uses: actions/checkout@v4
+        uses: actions/checkout@v6
 
       - name: Setup Go
-        uses: actions/setup-go@v5
+        uses: actions/setup-go@v6
         with:
-          go-version: "1.25"
+          go-version: "1.26"
 
       - name: Setup Python # This is for the build script
-        uses: actions/setup-python@v5
+        uses: actions/setup-python@v6
         with:
           python-version: "3.11"
 
diff --git a/.github/workflows/docker.yml b/.github/workflows/docker.yml
index daa0075..349d8ad 100644
