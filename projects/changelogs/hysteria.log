+
+func TestNextHopIntervalWithinRange(t *testing.T) {
+	u := &udpHopPacketConn{
+		HopInterval: HopIntervalConfig{
+			Min: 10 * time.Second,
+			Max: 30 * time.Second,
+		},
+	}
+
+	for i := 0; i < 1000; i++ {
+		d := u.nextHopInterval()
+		require.GreaterOrEqual(t, d, 10*time.Second)
+		require.LessOrEqual(t, d, 30*time.Second)
+	}
+}

